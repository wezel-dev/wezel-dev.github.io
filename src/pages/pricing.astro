---
import Base from '../layouts/Base.astro';

const tiers = [
  {
    name: "Self-Hosted",
    price: "Free",
    priceSub: "forever",
    description: "Run the full stack on your own infrastructure. No limits, no strings.",
    accentVar: "--green",
    glowVar: "--green-dim",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1"/><circle cx="6" cy="18" r="1"/></svg>`,
    features: [
      { text: "Pheromone agent", ok: true },
      { text: "Anthill dashboard", ok: true },
      { text: "Burrow backend", ok: true },
      { text: "Unlimited developers", ok: true },
      { text: "Unlimited scenarios", ok: true },
      { text: "Unlimited retention", ok: true },
      { text: "Community support", ok: true },
      { text: "Regression alerts", ok: false },
      { text: "CI integration", ok: false },
      { text: "Team analytics", ok: false },
    ],
    cta: "Get Started",
    ctaHref: "https://github.com/niclas-AQ/wezel",
    ctaStyle: "secondary",
    external: true,
  },
  {
    name: "Team",
    price: "$18",
    priceSub: "/ dev / month",
    description: "Hosted Wezel with regression detection and CI integration. Focus on code, not infra.",
    accentVar: "--accent",
    glowVar: "--accent-glow",
    highlight: true,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    features: [
      { text: "Everything in Self-Hosted", ok: true },
      { text: "Managed hosting", ok: true },
      { text: "Up to 30 developers", ok: true },
      { text: "90-day data retention", ok: true },
      { text: "Regression alerts", ok: true },
      { text: "GitHub / GitLab CI integration", ok: true },
      { text: "Scenario trend reports", ok: true },
      { text: "Email support", ok: true },
      { text: "SSO / SAML", ok: false },
      { text: "Custom Forager integrations", ok: false },
    ],
    cta: "Start Free Trial",
    ctaHref: "#",
    ctaStyle: "primary",
    external: false,
  },
  {
    name: "Enterprise",
    price: "$40",
    priceSub: "/ dev / month",
    description: "For organizations shipping at scale. Unlimited everything, dedicated support.",
    accentVar: "--cyan",
    glowVar: "--cyan-dim",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
    features: [
      { text: "Everything in Team", ok: true },
      { text: "Unlimited developers", ok: true },
      { text: "Unlimited data retention", ok: true },
      { text: "SSO / SAML", ok: true },
      { text: "Custom Forager integrations", ok: true },
      { text: "Org-wide build analytics", ok: true },
      { text: "Exportable ROI reports", ok: true },
      { text: "Dedicated support & SLA", ok: true },
      { text: "On-prem deployment assist", ok: true },
      { text: "Custom contract", ok: true },
    ],
    cta: "Contact Us",
    ctaHref: "mailto:sales@wezel.dev",
    ctaStyle: "secondary",
    external: false,
  },
];
---

<Base title="Pricing — Wezel">
  <section class="pricing-hero">
    <div class="pricing-hero-glow"></div>
    <div class="pricing-hero-content">
      <p class="section-label">Pricing</p>
      <h1 class="pricing-hero-title">
        Self-host for free.<br />
        <span class="pricing-hero-accent">Pay only for hosting.</span>
      </h1>
      <p class="pricing-hero-sub">
        The full Wezel stack is open source and always will be. Our paid plans
        add managed infrastructure, regression detection, and team analytics.
      </p>
    </div>
  </section>

  <section class="pricing-cards">
    <div class="pricing-grid">
      {tiers.map((tier) => (
        <div class:list={["tier-card", { "tier-highlight": tier.highlight }]} style={`--tier-accent: var(${tier.accentVar}); --tier-glow: var(${tier.glowVar});`}>
          {tier.highlight && <div class="tier-badge">Most Popular</div>}

          <div class="tier-header">
            <div class="tier-icon" set:html={tier.icon} />
            <span class="tier-name">{tier.name}</span>
          </div>

          <div class="tier-price-row">
            <span class="tier-price">{tier.price}</span>
            <span class="tier-price-sub">{tier.priceSub}</span>
          </div>

          <p class="tier-desc">{tier.description}</p>

          <a
            href={tier.ctaHref}
            class:list={["btn", tier.ctaStyle === "primary" ? "tier-btn-primary" : "tier-btn-secondary"]}
            target={tier.external ? "_blank" : undefined}
            rel={tier.external ? "noopener" : undefined}
          >
            {tier.cta}
          </a>

          <div class="tier-divider"></div>

          <ul class="tier-features">
            {tier.features.map((f) => (
              <li class:list={[f.ok ? "feat-yes" : "feat-no"]}>
                <span class="feat-icon">{f.ok ? "✓" : "—"}</span>
                <span>{f.text}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="pricing-faq">
    <div class="faq-inner">
      <p class="section-label">FAQ</p>
      <h2 class="faq-title">Common questions</h2>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>Is the free tier actually unlimited?</h3>
          <p>
            Yes. Self-hosted Wezel has no usage caps, no feature gates, and no telemetry.
            You run it, you own it.
          </p>
        </div>
        <div class="faq-item">
          <h3>What happens after the trial?</h3>
          <p>
            After 14 days, you choose a paid plan or export your data and self-host.
            We never hold your data hostage.
          </p>
        </div>
        <div class="faq-item">
          <h3>Can I switch plans later?</h3>
          <p>
            Anytime. Upgrade, downgrade, or move to self-hosted. Your data is portable — it's yours.
          </p>
        </div>
        <div class="faq-item">
          <h3>What build systems are supported?</h3>
          <p>
            Cargo (Rust) is supported today. Support for other build systems is on the roadmap
            and community-driven.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pricing-bottom-cta">
    <div class="pricing-bottom-glow"></div>
    <div class="pricing-bottom-inner">
      <p class="pricing-bottom-note">
        All paid plans include a <strong>14-day free trial</strong>. No credit card required.
      </p>
      <p class="pricing-bottom-contact">
        Need something custom?
        <a href="mailto:sales@wezel.dev" class="pricing-contact-link">Let's talk &rarr;</a>
      </p>
    </div>
  </section>
</Base>

<style is:global>
  /* ── Hero ───────────────────────────────────────────── */
  .pricing-hero {
    position: relative;
    overflow: hidden;
    padding: 4.5rem 2rem 3rem;
    text-align: center;
  }

  .pricing-hero-glow {
    position: absolute;
    top: -160px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 420px;
    background: radial-gradient(ellipse at center, var(--accent-glow-strong) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .pricing-hero-content {
    position: relative;
    z-index: 1;
    max-width: 620px;
    margin: 0 auto;
  }

  .pricing-hero-title {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .pricing-hero-accent {
    background: linear-gradient(135deg, var(--accent) 0%, #d4a878 50%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-hero-sub {
    font-size: 1.1rem;
    color: var(--text-mid);
    line-height: 1.65;
    max-width: 500px;
    margin: 0 auto;
  }

  /* ── Cards section ─────────────────────────────────── */
  .pricing-cards {
    padding: 2rem 2rem 3rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 1060px;
    margin: 0 auto;
    align-items: start;
  }

  /* ── Tier card ─────────────────────────────────────── */
  .tier-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .tier-card:hover {
    border-color: var(--border-light);
    box-shadow: 0 6px 32px rgba(0, 0, 0, 0.2);
  }

  .tier-highlight {
    border-color: var(--tier-accent);
    box-shadow:
      0 0 40px var(--tier-glow),
      0 4px 24px rgba(0, 0, 0, 0.25);
  }

  .tier-highlight:hover {
    border-color: var(--tier-accent);
    box-shadow:
      0 0 56px var(--accent-glow-strong),
      0 8px 40px rgba(0, 0, 0, 0.3);
  }

  /* ── Badge ─────────────────────────────────────────── */
  .tier-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--tier-accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    padding: 3px 12px;
    border-radius: 4px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ── Header ────────────────────────────────────────── */
  .tier-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.25rem;
    color: var(--tier-accent);
  }

  .tier-icon {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--tier-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .tier-name {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Price ──────────────────────────────────────────── */
  .tier-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 0.6rem;
  }

  .tier-price {
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .tier-price-sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  /* ── Description ───────────────────────────────────── */
  .tier-desc {
    font-size: 0.88rem;
    color: var(--text-mid);
    line-height: 1.55;
    margin-bottom: 1.5rem;
    min-height: 2.8em;
  }

  /* ── CTA buttons ───────────────────────────────────── */
  .tier-btn-primary {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.7rem 1.25rem;
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    cursor: pointer;
    background: var(--tier-accent);
    color: var(--bg);
    border: 1.5px solid var(--tier-accent);
    box-shadow: 0 0 20px var(--tier-glow);
    transition: all 0.2s ease;
  }

  .tier-btn-primary:hover {
    box-shadow: 0 0 36px var(--accent-glow-strong);
    transform: translateY(-1px);
  }

  .tier-btn-secondary {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.7rem 1.25rem;
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    cursor: pointer;
    background: transparent;
    color: var(--tier-accent);
    border: 1.5px solid var(--tier-accent);
    transition: all 0.2s ease;
  }

  .tier-btn-secondary:hover {
    background: var(--tier-glow);
    transform: translateY(-1px);
  }

  /* ── Divider ───────────────────────────────────────── */
  .tier-divider {
    height: 1px;
    background: var(--border);
    margin: 1.5rem 0 1.25rem;
  }

  /* ── Feature list ──────────────────────────────────── */
  .tier-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .tier-features li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .feat-icon {
    flex-shrink: 0;
    width: 18px;
    text-align: center;
    font-weight: 700;
    font-size: 0.82rem;
  }

  .feat-yes {
    color: var(--text-mid);
  }

  .feat-yes .feat-icon {
    color: var(--tier-accent);
  }

  .feat-no {
    color: var(--text-dim);
    opacity: 0.6;
  }

  .feat-no .feat-icon {
    color: var(--text-dim);
  }

  /* ── FAQ ────────────────────────────────────────────── */
  .pricing-faq {
    padding: 3.5rem 2rem;
    border-top: 1px solid var(--border);
  }

  .faq-inner {
    max-width: 780px;
    margin: 0 auto;
  }

  .faq-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 2rem;
    line-height: 1.2;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }

  .faq-item:hover {
    border-color: var(--border-light);
  }

  .faq-item h3 {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .faq-item p {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  /* ── Bottom CTA ────────────────────────────────────── */
  .pricing-bottom-cta {
    position: relative;
    overflow: hidden;
    padding: 3rem 2rem 4rem;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .pricing-bottom-glow {
    position: absolute;
    bottom: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .pricing-bottom-inner {
    position: relative;
    z-index: 1;
  }

  .pricing-bottom-note {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-mid);
    margin-bottom: 0.6rem;
    line-height: 1.6;
  }

  .pricing-bottom-note strong {
    color: var(--text);
    font-weight: 600;
  }

  .pricing-bottom-contact {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-dim);
  }

  .pricing-contact-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.15s;
  }

  .pricing-contact-link:hover {
    color: #c09878;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }

    .pricing-hero-title {
      font-size: 2.2rem;
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .pricing-hero {
      padding: 3rem 1.25rem 2rem;
    }

    .pricing-cards {
      padding: 1.5rem 1.25rem 2rem;
    }

    .pricing-faq {
      padding: 2.5rem 1.25rem;
    }

    .pricing-hero-title {
      font-size: 1.9rem;
    }

    .pricing-hero-sub {
      font-size: 1rem;
    }
  }
</style>