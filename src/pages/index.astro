---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-content">
      <p class="section-label">Open-source build observability</p>
      <h1 class="hero-title">
        Love your build.<br />
        <span class="hero-accent">Again.</span>
      </h1>
      <p class="hero-sub">
        Wezel catches build regressions before they slow your team down.
        Know what changed, what broke, and how much time it costs — automatically.
      </p>
      <div class="hero-ctas">
        <a href="https://github.com/niclas-AQ/wezel" class="btn btn-lg btn-primary" target="_blank" rel="noopener">
          Get Started
        </a>
        <a href="/pricing" class="btn btn-lg btn-secondary">
          See Pricing &rarr;
        </a>
      </div>

      <div class="hero-terminal">
        <div class="terminal-bar">
          <span class="terminal-dot" style="background: var(--red)"></span>
          <span class="terminal-dot" style="background: var(--amber)"></span>
          <span class="terminal-dot" style="background: var(--green)"></span>
          <span class="terminal-title">terminal</span>
        </div>
        <div class="terminal-body">
          <span class="t-prompt">$</span> <span class="t-cmd">cargo build</span><br />
          <span class="t-dim">   Compiling 142 crates...</span><br />
          <span class="t-dim">   Finished in 47.3s</span><br /><br />
          <span class="t-prompt">$</span> <span class="t-cmd">wezel status</span><br />
          <span class="t-accent">⚠ regression detected</span> <span class="t-dim">on scenario</span> <span class="t-text">dev-build</span><br />
          <span class="t-dim">  commit</span> <span class="t-cyan">a3f8c1d</span> <span class="t-dim">added</span> <span class="t-warn">+12.4s</span> <span class="t-dim">(+26%)</span><br />
          <span class="t-dim">  cause:</span> <span class="t-text">new generic impl in <span class="t-cyan">core::parser</span></span><br />
          <span class="t-dim">  affected crates:</span> <span class="t-text">38 downstream rebuilds</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How it works ──────────────────────────────────── -->
  <section class="how">
    <div class="how-inner">
      <p class="section-label">Architecture</p>
      <h2 class="section-title">Four components, one mission</h2>
      <p class="section-sub">
        Wezel is a suite of tools that fit into your existing workflow with zero friction.
      </p>

      <div class="how-grid">
        <div class="how-card">
          <div class="how-card-icon" style="background: var(--green-dim); color: var(--green);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3>Pheromone</h3>
          <p class="how-card-role">Local agent</p>
          <p class="how-card-desc">
            Hooks into your shell. Captures every build invocation automatically. Zero config, near-zero overhead.
          </p>
        </div>

        <div class="how-card">
          <div class="how-card-icon" style="background: var(--accent-glow); color: var(--accent);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </div>
          <h3>Anthill</h3>
          <p class="how-card-role">Dashboard</p>
          <p class="how-card-desc">
            Visualize build performance across your team. Spot trends, compare scenarios, drill into the details.
          </p>
        </div>

        <div class="how-card">
          <div class="how-card-icon" style="background: var(--cyan-dim); color: var(--cyan);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <h3>Burrow</h3>
          <p class="how-card-role">Backend</p>
          <p class="how-card-desc">
            Ingests events, stores history, serves data. Self-host it or let us run it — your data, your rules.
          </p>
        </div>

        <div class="how-card">
          <div class="how-card-icon" style="background: rgba(184, 152, 96, 0.12); color: var(--amber);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Forager</h3>
          <p class="how-card-role">Scenario runner</p>
          <p class="how-card-desc">
            Runs repeatable build scenarios in CI so you can benchmark what actually matters — deterministically.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Why Wezel ─────────────────────────────────────── -->
  <section class="why">
    <div class="why-inner">
      <p class="section-label">Why Wezel</p>
      <h2 class="section-title">Builds rot. Wezel fights entropy.</h2>

      <div class="why-grid">
        <div class="why-card">
          <div class="why-marker" style="background: var(--red);"></div>
          <h3>Catch regressions early</h3>
          <p>
            Get alerted the moment a change makes your most-used build scenario slower.
            Know exactly which commit, which crate, how much time.
          </p>
        </div>
        <div class="why-card">
          <div class="why-marker" style="background: var(--accent);"></div>
          <h3>Understand your build</h3>
          <p>
            See which scenarios your team runs the most. Focus optimization effort on what matters,
            not on guesswork.
          </p>
        </div>
        <div class="why-card">
          <div class="why-marker" style="background: var(--green);"></div>
          <h3>Open source, no lock-in</h3>
          <p>
            Self-host the entire stack for free, forever. No telemetry, no vendor lock-in.
            MIT-licensed and community-driven.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA ────────────────────────────────────── -->
  <section class="bottom-cta">
    <div class="bottom-cta-glow"></div>
    <div class="bottom-cta-inner">
      <h2>Ready to keep your builds fast?</h2>
      <p>Install Pheromone, point it at Anthill, and never be surprised by a slow build again.</p>
      <div class="bottom-cta-buttons">
        <a href="https://github.com/niclas-AQ/wezel" class="btn btn-lg btn-primary" target="_blank" rel="noopener">
          Get Started on GitHub
        </a>
        <a href="/pricing" class="btn btn-lg btn-secondary">
          View Pricing
        </a>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* ── Hero ───────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 2rem 4rem;
  }

  .hero-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse at center, var(--accent-glow-strong) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    font-size: 3.6rem;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .hero-accent {
    background: linear-gradient(135deg, var(--accent) 0%, #d4a878 50%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-mid);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto 2.25rem;
  }

  .hero-ctas {
    display: flex;
    gap: 0.85rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  /* ── Terminal mockup ───────────────────────────────── */
  .hero-terminal {
    max-width: 560px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-deep);
    overflow: hidden;
    text-align: left;
    box-shadow:
      0 8px 40px rgba(0, 0, 0, 0.35),
      0 0 60px var(--accent-glow);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.7;
  }

  .terminal-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .terminal-body {
    padding: 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.75;
    color: var(--text-dim);
  }

  .t-prompt { color: var(--green); font-weight: 600; }
  .t-cmd { color: var(--text); font-weight: 500; }
  .t-dim { color: var(--text-dim); }
  .t-text { color: var(--text-mid); }
  .t-accent { color: var(--accent); font-weight: 600; }
  .t-cyan { color: var(--cyan); }
  .t-warn { color: var(--red); font-weight: 600; }

  /* ── Section shared ────────────────────────────────── */
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    text-align: center;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--text-mid);
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── How it works ──────────────────────────────────── */
  .how {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
  }

  .how-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .how-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .how-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .how-card:hover {
    border-color: var(--border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .how-card-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .how-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.15rem;
    letter-spacing: -0.01em;
  }

  .how-card-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--cyan);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }

  .how-card-desc {
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.55;
  }

  /* ── Why Wezel ─────────────────────────────────────── */
  .why {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
  }

  .why-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .why-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .why-card:hover {
    border-color: var(--border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .why-marker {
    width: 4px;
    height: 28px;
    border-radius: 2px;
    margin-bottom: 1rem;
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }

  .why-card p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  /* ── Bottom CTA ────────────────────────────────────── */
  .bottom-cta {
    position: relative;
    padding: 5rem 2rem;
    border-top: 1px solid var(--border);
    overflow: hidden;
  }

  .bottom-cta-glow {
    position: absolute;
    bottom: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .bottom-cta-inner {
    position: relative;
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
    z-index: 1;
  }

  .bottom-cta-inner h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .bottom-cta-inner p {
    font-size: 1rem;
    color: var(--text-mid);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .bottom-cta-buttons {
    display: flex;
    gap: 0.85rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 900px) {
    .how-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3.5rem 1.25rem 3rem;
    }

    .hero-title {
      font-size: 2.4rem;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .hero-terminal {
      max-width: 100%;
    }

    .terminal-body {
      font-size: 0.75rem;
      padding: 1rem;
    }

    .section-title {
      font-size: 1.6rem;
    }

    .how, .why, .bottom-cta {
      padding: 3rem 1.25rem;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .bottom-cta-inner h2 {
      font-size: 1.6rem;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }

    .how-grid {
      grid-template-columns: 1fr;
    }
  }
</style>