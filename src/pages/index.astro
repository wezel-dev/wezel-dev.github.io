---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-content">
      <p class="section-label">Open-source build observability</p>
      <h1 class="hero-title">
        Your build,<br />
        <span class="hero-accent">always at its best.</span>
      </h1>
      <p class="hero-sub">
        Wezel catches build regressions before they slow your team down.
        Know what changed, what broke, and how much time it costs — automatically.
      </p>
      <div class="hero-ctas">
        <a href="https://github.com/wezel-build/wezel" class="btn btn-lg btn-primary" target="_blank" rel="noopener">
          Get Started
        </a>
        <a href="/pricing" class="btn btn-lg btn-secondary">
          See Pricing &rarr;
        </a>
      </div>

      <div class="hero-terminal">
        <div class="terminal-bar">
          <span class="terminal-dot" style="background: var(--red)"></span>
          <span class="terminal-dot" style="background: var(--amber)"></span>
          <span class="terminal-dot" style="background: var(--green)"></span>
          <span class="terminal-title">terminal</span>
        </div>
        <div class="terminal-body">
          <span class="t-prompt">$</span> <span class="t-cmd">cargo build</span><br />
          <span class="t-dim">   Compiling 142 crates...</span><br />
          <span class="t-dim">   Finished in 47.3s</span><br /><br />
          <span class="t-prompt">$</span> <span class="t-cmd">wezel status</span><br />
          <span class="t-accent">⚠ regression detected</span> <span class="t-dim">on scenario</span> <span class="t-text">dev-build</span><br />
          <span class="t-dim">  commit</span> <span class="t-cyan">a3f8c1d</span> <span class="t-dim">added</span> <span class="t-warn">+12.4s</span> <span class="t-dim">(+26%)</span><br />
          <span class="t-dim">  cause:</span> <span class="t-text">new generic impl in <span class="t-cyan">core::parser</span></span><br />
          <span class="t-dim">  affected crates:</span> <span class="t-text">38 downstream rebuilds</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How it works ──────────────────────────────────── -->
  <section class="how">
    <div class="how-inner">
      <p class="section-label">How it works</p>
      <h2 class="section-title">Find it. Track it. Prevent it.</h2>
      <p class="section-sub">
        Wezel zeroes in on the build scenarios that hurt your team most, then makes sure they never quietly get worse.
      </p>

      <div class="how-grid how-grid-3">
        <div class="how-card">
          <div class="how-card-icon" style="background: var(--green-dim); color: var(--green);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3>Find the pain</h3>
          <p class="how-card-desc">
            Wezel observes real builds across your whole team — no manual instrumentation needed. It surfaces which scenarios eat the most time, for the most people, most often.
          </p>
        </div>

        <div class="how-card">
          <div class="how-card-icon" style="background: var(--accent-glow); color: var(--accent);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Track it continuously</h3>
          <p class="how-card-desc">
            Your most critical scenarios are benchmarked on every commit in CI. A full history lets you see exactly when things changed and how the trend is moving.
          </p>
        </div>

        <div class="how-card">
          <div class="how-card-icon" style="background: rgba(184, 152, 96, 0.12); color: var(--amber);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3>Prevent regressions</h3>
          <p class="how-card-desc">
            The moment a commit adds meaningful build time, Wezel tells you — which commit, how much time, what it affected. Catch it while it's still fresh and easy to revisit, not months later when it's your new normal.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Why Wezel ─────────────────────────────────────── -->
  <section class="why">
    <div class="why-inner">
      <p class="section-label">Why Wezel</p>
      <h2 class="section-title">Slow builds don't announce themselves.</h2>

      <div class="why-grid">
        <div class="why-card">
          <div class="why-marker" style="background: var(--red);"></div>
          <h3>Pain you didn't know you had</h3>
          <p>
            Build time creep is invisible until it's unbearable. Wezel quantifies the real cost —
            aggregate wait time across your whole team — so you can prioritize what's actually worth fixing.
          </p>
        </div>
        <div class="why-card">
          <div class="why-marker" style="background: var(--accent);"></div>
          <h3>Regressions that hide in plain sight</h3>
          <p>
            A change that adds 15 seconds to your most common build scenario is death by a thousand cuts.
            Wezel catches it while it's still a single commit, not after it's baked into your baseline.
          </p>
        </div>
        <div class="why-card">
          <div class="why-marker" style="background: var(--green);"></div>
          <h3>Open source, your data</h3>
          <p>
            Self-host the entire stack for free, forever. No telemetry, no vendor lock-in.
            MIT-licensed and community-driven.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA ────────────────────────────────────── -->
  <section class="bottom-cta">
    <div class="bottom-cta-glow"></div>
    <div class="bottom-cta-inner">
      <h2>Stop accepting slow builds as normal.</h2>
      <p>Find your most painful scenarios, track them on every commit, and get alerted before regressions reach your team.</p>
      <div class="bottom-cta-buttons">
        <a href="https://github.com/wezel-build/wezel" class="btn btn-lg btn-primary" target="_blank" rel="noopener">
          Get Started on GitHub
        </a>
        <a href="/pricing" class="btn btn-lg btn-secondary">
          View Pricing
        </a>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* ── Hero ───────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 2rem 4rem;
  }

  .hero-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse at center, var(--accent-glow-strong) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    font-size: 3.6rem;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .hero-accent {
    background: linear-gradient(135deg, var(--accent) 0%, #d4a878 50%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-mid);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto 2.25rem;
  }

  .hero-ctas {
    display: flex;
    gap: 0.85rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  /* ── Terminal mockup ───────────────────────────────── */
  .hero-terminal {
    max-width: 560px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-deep);
    overflow: hidden;
    text-align: left;
    box-shadow:
      0 8px 40px rgba(0, 0, 0, 0.35),
      0 0 60px var(--accent-glow);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.7;
  }

  .terminal-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .terminal-body {
    padding: 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.75;
    color: var(--text-dim);
  }

  .t-prompt { color: var(--green); font-weight: 600; }
  .t-cmd { color: var(--text); font-weight: 500; }
  .t-dim { color: var(--text-dim); }
  .t-text { color: var(--text-mid); }
  .t-accent { color: var(--accent); font-weight: 600; }
  .t-cyan { color: var(--cyan); }
  .t-warn { color: var(--red); font-weight: 600; }

  /* ── Section shared ────────────────────────────────── */
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    text-align: center;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--text-mid);
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── How it works ──────────────────────────────────── */
  .how {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
  }

  .how-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .how-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .how-grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .how-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .how-card:hover {
    border-color: var(--border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .how-card-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .how-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.15rem;
    letter-spacing: -0.01em;
  }

  .how-card-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--cyan);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
  }

  .how-card-desc {
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.55;
  }

  /* ── Why Wezel ─────────────────────────────────────── */
  .why {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
  }

  .why-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .why-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .why-card:hover {
    border-color: var(--border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .why-marker {
    width: 4px;
    height: 28px;
    border-radius: 2px;
    margin-bottom: 1rem;
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }

  .why-card p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  /* ── Bottom CTA ────────────────────────────────────── */
  .bottom-cta {
    position: relative;
    padding: 5rem 2rem;
    border-top: 1px solid var(--border);
    overflow: hidden;
  }

  .bottom-cta-glow {
    position: absolute;
    bottom: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .bottom-cta-inner {
    position: relative;
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
    z-index: 1;
  }

  .bottom-cta-inner h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .bottom-cta-inner p {
    font-size: 1rem;
    color: var(--text-mid);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .bottom-cta-buttons {
    display: flex;
    gap: 0.85rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 900px) {
    .how-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .how-grid-3 {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3.5rem 1.25rem 3rem;
    }

    .hero-title {
      font-size: 2.4rem;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .hero-terminal {
      max-width: 100%;
    }

    .terminal-body {
      font-size: 0.75rem;
      padding: 1rem;
    }

    .section-title {
      font-size: 1.6rem;
    }

    .how, .why, .bottom-cta {
      padding: 3rem 1.25rem;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .bottom-cta-inner h2 {
      font-size: 1.6rem;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }

    .how-grid {
      grid-template-columns: 1fr;
    }
  }
</style>