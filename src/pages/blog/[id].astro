---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} — Wezel`}>
  <article class="blog-post">
    <header class="blog-post-header">
      <a href="/blog" class="blog-back">&larr; All posts</a>
      <time class="blog-post-date" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="blog-post-title">{post.data.title}</h1>
      <p class="blog-post-desc">{post.data.description}</p>
    </header>
    <div class="blog-post-body">
      <Content />
    </div>
  </article>
</Base>

<style is:global>
  .blog-post {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .blog-post-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2rem;
  }

  .blog-back {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.15s;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .blog-back:hover {
    color: var(--accent);
  }

  .blog-post-date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.02em;
    margin-bottom: 0.75rem;
  }

  .blog-post-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 0.6rem;
  }

  .blog-post-desc {
    font-size: 1.05rem;
    color: var(--text-mid);
    line-height: 1.6;
  }

  /* ── Post body prose ── */
  .blog-post-body {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-mid);
  }

  .blog-post-body h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin: 2.5rem 0 0.75rem;
    line-height: 1.25;
  }

  .blog-post-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 2rem 0 0.5rem;
    line-height: 1.3;
  }

  .blog-post-body p {
    margin-bottom: 1.25rem;
  }

  .blog-post-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .blog-post-body a:hover {
    color: #c09878;
  }

  .blog-post-body ul,
  .blog-post-body ol {
    margin: 0 0 1.25rem 1.5rem;
  }

  .blog-post-body ul {
    list-style: disc;
  }

  .blog-post-body ol {
    list-style: decimal;
  }

  .blog-post-body li {
    margin-bottom: 0.35rem;
  }

  .blog-post-body blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--text-dim);
    font-style: italic;
  }

  .blog-post-body code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface2);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--text);
  }

  .blog-post-body pre {
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.65;
  }

  .blog-post-body pre code {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .blog-post-body hr {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 2.5rem 0;
  }

  .blog-post-body img {
    border-radius: var(--radius);
    margin: 1.5rem 0;
  }

  .blog-post-body strong {
    color: var(--text);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .blog-post {
      padding: 2rem 1.25rem 4rem;
    }

    .blog-post-title {
      font-size: 1.7rem;
    }
  }
</style>
