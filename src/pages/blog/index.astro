---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Blog — Wezel">
  <section class="blog-hero">
    <div class="blog-hero-content">
      <p class="section-label">Blog</p>
      <h1 class="blog-hero-title">From the hive</h1>
      <p class="blog-hero-sub">
        Thoughts on build performance, developer tooling, and building Wezel.
      </p>
    </div>
  </section>

  <section class="blog-list">
    <div class="blog-list-inner">
      {posts.length === 0 && (
        <p class="blog-empty">No posts yet. Check back soon.</p>
      )}
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="blog-card">
          <time class="blog-card-date" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2 class="blog-card-title">{post.data.title}</h2>
          <p class="blog-card-desc">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Base>

<style is:global>
  .blog-hero {
    padding: 4.5rem 2rem 2.5rem;
    text-align: center;
  }

  .blog-hero-content {
    max-width: 560px;
    margin: 0 auto;
  }

  .blog-hero-title {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .blog-hero-sub {
    font-size: 1.05rem;
    color: var(--text-mid);
    line-height: 1.6;
  }

  .blog-list {
    padding: 1rem 2rem 4rem;
  }

  .blog-list-inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-empty {
    text-align: center;
    color: var(--text-dim);
    font-size: 0.95rem;
    padding: 3rem 0;
  }

  .blog-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .blog-card:hover {
    border-color: var(--border-light);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .blog-card-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .blog-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin: 0.35rem 0 0.4rem;
    line-height: 1.3;
  }

  .blog-card-desc {
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.55;
  }

  [data-theme="light"] .blog-card:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  @media (max-width: 640px) {
    .blog-hero {
      padding: 3rem 1.25rem 2rem;
    }

    .blog-list {
      padding: 1rem 1.25rem 3rem;
    }

    .blog-hero-title {
      font-size: 1.9rem;
    }
  }
</style>
